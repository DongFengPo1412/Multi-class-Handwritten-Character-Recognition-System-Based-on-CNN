profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally check in Pipfile.lock.
#   For libraries, you should ignore the lockfile.
#   For applications, you should check it in.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock should be ignored for libraries, but check it in for applications.
# poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock should be ignored for libraries, but check it in for applications.
# pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

